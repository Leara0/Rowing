@page "/traininglibrary"
@using System.Net
@using System.Text.Json
@using Rowing.Application.DrillTechniqueUseCase.QueryServices
@using Rowing.Application.UseCases.TrainingWorkoutsUseCase.QueryServices
@using Rowing.Domain.Enums
@inject HttpClient Http



<PageTitle>Training Library - CatchPoint</PageTitle>

<!-- Search Bar section -->
<div class="search-container">
    <select @bind="selectedField">
        <option value="All">All Fields</option>
        <option value="Name">Name Only</option>
        <option value="Description">Description Only</option>
    </select>
    
    <input type="text" placeholder="Search exercises and drills..." value="@searchTerm" @oninput="OnSearchInput" />
    
    <button @onclick="SearchNow">Search</button>
    <button @onclick="ClearSearch">Clear Search</button>

</div>

<!-- Training Exercise section -->
<h2 class="type-heading">Exercises</h2>
@if (hasActiveSearch && !searchedExercises.Any())
{
    <p>
        No results found for @searchTerm
    </p>
}    
<div class="exercises-grid">
    @foreach (var exercise in hasActiveSearch ? searchedExercises : exercises)
    {
        <div class="exercise-card" @onclick="() => ShowExerciseDetails(exercise)">
            <h4>
                @exercise.Name
            </h4>
            <p>
                @exercise.DurationMinutes min •
                @exercise.IntensityLevel
            </p>
            <p>
                @TruncateText(exercise.TrainingGoal, 50)
            </p>
        </div>
    }
</div>

<!-- Exercise Modal Card -->
@if (selectedExercise != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="exercise-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@selectedExercise.Name</h3>
                <button @onclick="CloseModal">×</button>
            </div>
            <div class="modal-body">
                <p><strong>Duration:</strong> @selectedExercise.DurationMinutes minutes</p>
                <p><strong>Workout Type:</strong> @selectedExercise.WorkoutType</p>
                <p><strong>Intensity:</strong> @selectedExercise.IntensityLevel</p>
                <p><strong>Stroke Rate:</strong> @selectedExercise.TargetStrokeRate</p>
                <p><strong>Description:</strong> @selectedExercise.Description</p>
                <p><strong>Training Goal:</strong> @selectedExercise.TrainingGoal</p>
            </div>
        </div>
    </div>
}

<!-- Technique Drills section -->
<h2 class="type-heading">Drills</h2>
@if (hasActiveSearch && !searchedDrills.Any())
 {
     <p>
         No results found for @searchTerm
     </p>
 }

<div class="drills-grid">
    @foreach (var drill in hasActiveSearch? searchedDrills : drills)
    {
        <div class="drill-card" @onclick="() => ShowDrillDetails(drill)">
            <h4>
                @drill.Name
            </h4>
            <p>
                Focus: @drill.FocusArea
            </p>
            <p>
                @TruncateText(drill.Description, 50)
            </p>
        </div>
    }
</div>

<!-- Drill Modal Card -->
@if (selectedDrill != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="drill-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@selectedDrill.Name</h3>
                <button @onclick="CloseModal">×</button>
            </div>
            <div class="modal-body">
                <p><strong>Focus Area:</strong> @selectedDrill.FocusArea</p>
                <p><strong>Description:</strong> @selectedDrill.Description</p>
                <p><strong>Execution Steps:</strong> @selectedDrill.ExecutionSteps</p>
                <p><strong>Coaching Points:</strong> @selectedDrill.CoachingPoints</p>
                <p><strong>Progression:</strong> @selectedDrill.Progression</p>
            </div>
        </div>
    </div>
}

@code {
    
    // search state variables
    private string searchTerm = "";
    private SearchField selectedField = SearchField.All;
    
    // to know when to show search results vs full lists
    private bool hasActiveSearch = false;
    
    // lists for showing all
    private List<TechniqueDrillDto> drills = new();
    private List<TrainingWorkoutDto> exercises = new();
    
    // lists for search results
    private List<TechniqueDrillDto> searchedDrills = new();
    private List<TrainingWorkoutDto> searchedExercises = new();
    
    // timer for debouncing auto searching
    private System.Threading.Timer? _searchTimer;
    
    // holds selected item for modal overlay
    private TechniqueDrillDto selectedDrill = null;
    private TrainingWorkoutDto selectedExercise = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadTechniqueDrillData();
        await LoadTrainingWorkoutData();
    }
    
    private async Task LoadTechniqueDrillData()
    {
        try
        {
            drills = await Http.GetFromJsonAsync<List<TechniqueDrillDto>>("api/TechniqueDrill");
            Console.WriteLine($"Loaded {drills.Count} technique drills");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading technique drills: {ex.Message}");
        }
    }

    private async Task LoadTrainingWorkoutData()
    {
        try
        {
            exercises = await Http.GetFromJsonAsync<List<TrainingWorkoutDto>>("api/TrainingWorkout");
            Console.WriteLine($"Loaded {exercises.Count} exercises");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading exercises: {ex.Message}");
        }
    }

    private string TruncateText(string description, int length)
    {
        if (string.IsNullOrEmpty(description))
            return "No description information could be found.";
        if (description.Length <= length)
            return description;
        else
            return description.Substring(0, length) + "...";
    }
    private async Task SearchNow()
    {
        hasActiveSearch = true;
        
        // clear previous results
        searchedDrills = new();
        searchedExercises = new();

        try
        {
            searchedDrills = await Http.GetFromJsonAsync<List<TechniqueDrillDto>>
                ($"api/TechniqueDrill/search?term={searchTerm}&field={selectedField}");
            Console.WriteLine($"Loaded {searchedDrills.Count} technique drills");

            searchedExercises = await Http.GetFromJsonAsync<List<TrainingWorkoutDto>>
                ($"api/TrainingWorkout/search?term={searchTerm}&field={selectedField}");
            Console.WriteLine($"Loaded {searchedExercises.Count} exercises");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search error {ex.Message}");
        }
    }

    private void ClearSearch()
    {
        searchTerm = "";
        selectedField = SearchField.All;
        hasActiveSearch = false;
        searchedDrills = new();
        searchedExercises = new();
    }
    
    // card modal functionality
    private void ShowExerciseDetails(TrainingWorkoutDto exercise)
    {
        selectedExercise = exercise;
    }

    private void ShowDrillDetails(TechniqueDrillDto drill)
    {
        selectedDrill = drill;
    }

    private void CloseModal()
    {
        selectedExercise = null;
        selectedDrill = null;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        
        //cancel any existing timer
        _searchTimer?.Dispose();
        
        // start new timer that fires 300ms after typing stops
        _searchTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(SearchNow);
        }, null, 300, Timeout.Infinite);
    }
}




